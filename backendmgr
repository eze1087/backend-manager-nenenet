nginx_real_bin() {
  # Usa el binario REAL de nginx para evitar wrappers rotos en /usr/local/bin/nginx
  local c
  for c in /usr/sbin/nginx.real /usr/sbin/nginx /usr/bin/nginx; do
    [[ -x "$c" ]] && { echo "$c"; return 0; }
  done
  command -v nginx 2>/dev/null || true
}

nginx_test_reload() {
  local ngx
  ngx="$(nginx_real_bin)"
  if [[ -z "${ngx:-}" || ! -x "${ngx:-}" ]]; then
    echo -e "${YLW}⚠️ nginx no está instalado.${NC}"
    return 0
  fi

  if ! timeout 10s "$ngx" -t >/dev/null 2>&1; then
    echo -e "${YLW}⚠️ nginx -t falló. No recargo.${NC}"
    return 0
  fi

  # Reload preferido por systemd para no depender del wrapper
  if command -v systemctl >/dev/null 2>&1; then
    timeout 8s systemctl reload nginx >/dev/null 2>&1 || timeout 8s systemctl restart nginx >/dev/null 2>&1 || true
  else
    timeout 8s "$ngx" -s reload >/dev/null 2>&1 || true
  fi
  return 0
}

# ✅ Banner con ancho automático (para que el recuadro “quede bien” siempre)
banner() {
  clear || true
  read_cfg 2>/dev/null || true

  local dt ip
  dt="$(date '+%d/%m/%Y %H:%M:%S')"
  ip="$(server_ip_short)"

  local ng_state dom_active bcount dcount bkp
  ng_state="$(nginx_state)"
  dom_active="$(primary_domain_active)"
  bcount="$(backend_count)"
  dcount="$(domain_count)"
  bkp="$(last_backup_info)"

  local traffic_s scan_s
  traffic_s="$(traffic_log_state_short)"
  scan_s="$(traffic_scan_state_short)"

  # Título
  local title="🔥  BACKEND MANAGER • El NeNe Full 3.0 v${APP_VER}  🔥"
  local W=78

  # Separadores (personalizados, 2 estilos)
  local SEP_THIN SEP_THICK
  SEP_THIN="$(printf "%*s" "$W" "" | tr " " "-")"
  SEP_THICK="$(printf "%*s" "$W" "" | tr " " "=")"

  # Barra de título
  printf "${BG_RED}${WHT}%s${NC}${BG_NONE}
" "$(disp_center_fit "$title" "$W")"

  # ======= BLOQUE SUPERIOR (SIN FONDO, SOLO COLOR DE LETRA) =======
  printf "${BBLU}%s${NC}
" "$SEP_THIN"
  printf "  ${BCYA}📅 FECHA:${NC} ${GRN}%-19s${NC}   ${BCYA}🌐 IP:${NC} ${GRN}%-15s${NC}
" "$dt" "$ip"
  printf "${BBLU}%s${NC}
" "$SEP_THICK"

  # Estado general
  local ngx_label ngx_color
  if [[ "$ng_state" == "ON" ]]; then ngx_label="✅ ACTIVO"; ngx_color="${BGRN}"; else ngx_label="❌ OFF"; ngx_color="${BRED}"; fi

  printf "  ${BCYA}⚙️  Nginx:${NC} ${ngx_color}%-10s${NC}   ${BCYA}📁 Dominios:${NC} ${GRN}%-3s${NC}   ${BCYA}🧱 Backends:${NC} ${GRN}%-3s${NC}
" "$ngx_label" "$dcount" "$bcount"
  printf "  ${BCYA}👑 Dominio madre:${NC} ${GRN}%-52s${NC}
" "$(disp_trunc "$dom_active" 52)"
  printf "  ${BCYA}🏷️  Header:${NC} ${GRN}%-12s${NC}   ${BCYA}📈 Tráfico:${NC} ${GRN}%-12s${NC}   ${BCYA}🔎 Scanner:${NC} ${GRN}%-18s${NC}
" \
    "$(disp_trunc "$HEADER_NAME" 12)" "$(disp_trunc "$traffic_s" 12)" "$(disp_trunc "$scan_s" 18)"
  printf "  ${BCYA}💾 Backup:${NC} ${GRN}%-60s${NC}
" "$(disp_trunc "$bkp" 60)"

  printf "${BBLU}%s${NC}
" "$SEP_THICK"

  # Recursos (mismo contenido, distinto tono para separarlo del menú)
  local dl ml cl nl rl
  dl="$(strip_ansi "$(disk_usage_line)" | sed 's/^💽 DISK: /💽 DISCO: /')"
  ml="$(strip_ansi "$(mem_used_line)")"
  cl="$(strip_ansi "$(cpu_line)")"
  nl="$(strip_ansi "$(net_totals_line)" | sed 's/^📡 NET: /📡 RED: /')"
  rl="$(strip_ansi "$(ramrefresh_last_line)")"

  __banner_kv() {
    local s="$1" label rest
    label="${s%%:*}"
    rest="${s#*:}"
    if [[ "$rest" == "$s" ]]; then
      printf "  ${BCYA}%s${NC}
" "$s"
    else
      rest="${rest# }"
      printf "  ${BCYA}%s:${NC} ${WHT}%s${NC}
" "$label" "$rest"
    fi
  }

  __banner_kv "$dl"
  __banner_kv "$ml"
  __banner_kv "$cl"
  __banner_kv "$nl"
  __banner_kv "$rl"


  printf "${BBLU}%s${NC}
" "$SEP_THIN"
  echo
}



