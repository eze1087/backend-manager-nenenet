}

payload_pick_backend_key() {
  # Usage:
  #   payload_pick_backend_key VAR   -> guarda el backend en VAR (recomendado)
  #   payload_pick_backend_key       -> imprime el backend por stdout (legacy)
  local __var="${1:-}"
  mapfile -t lines < <(backend_lines)
  local O; O="$(payload_out)"
  if [[ ${#lines[@]} -eq 0 ]]; then
    echo -e "${YLW}No hay backends cargados.${NC}" >"$O"
    return 1
  fi

  echo -e "${CYA}Elegí de la siguiente lista el backend a integrar:${NC}" >"$O"
  echo -e "${DIM}Seleccioná por número.${NC}" >"$O"
  echo "----------------------------------------------------------------" >"$O"

  local i=0 key url ipport ip port
  for line in "${lines[@]}"; do
    i=$((i+1))
    key="$(echo "$line" | sed -E 's/^\s*"([^"]+)".*/\1/')"
    url="$(echo "$line" | sed -E 's/^.*"\s+"([^"]+)";\s*$/\1/')"
    ipport="${url#http://}"; ip="${ipport%%:*}"; port="${ipport##*:}"
    printf " %3s) %-20s -> %s:%s\n" "$i" "$key" "$ip" "$port" >"$O"
  done
  echo "----------------------------------------------------------------" >"$O"

  local n
  if [[ -r /dev/tty ]]; then
    read -r -p "Número: " n </dev/tty
  else
    read -r -p "Número: " n
  fi
  [[ "$n" =~ ^[0-9]+$ ]] || { echo -e "${YLW}Inválido.${NC}" >"$O"; return 1; }
  (( n>=1 && n<=${#lines[@]} )) || { echo -e "${YLW}Fuera de rango.${NC}" >"$O"; return 1; }

  key="$(echo "${lines[$((n-1))]}" | sed -E 's/^\s*"([^"]+)".*/\1/')"
  if [[ -n "$__var" ]]; then
    printf -v "$__var" "%s" "$key"
  else
    echo "$key"
  fi
  return 0
}

payload_render() {
  local tpl="$1" backend="$2"
  local dom_list_override="${3:-}"
  local dom_rot_override="${4:-}"
  local hdr="$HEADER_NAME"

  local dom_list dom_rot
  if [[ -n "$dom_list_override" ]]; then
    dom_list="$dom_list_override"
    dom_rot="${dom_rot_override:-[rotate=${dom_list_override}]}"
  else
    dom_list="$(payload_domains_join_semicolon)"
    dom_rot="$(payload_domains_rotate)"
  fi

  local out
  out="$(printf "%s" "$tpl" | sed \
    -e "s/{HEADER}/${hdr}/g" \
    -e "s/{BACKEND}/${backend}/g" \
    -e "s/{MOTHERS_LIST}/${dom_list}/g" \
    -e "s/{MOTHERS_ROTATE}/${dom_rot}/g")"

  out="$(printf "%s" "$out" | sed -E \
    -e "s/(${hdr}|Backend):[[:space:]]*\.+/\\1:${backend}/g" \
    -e "s/(${hdr}|Backend):[[:space:]]*\.{2,}/\\1:${backend}/g")"

  printf "%s\n" "$out"
}

PAYLOAD_GEN_DIR="${PAYLOAD_DIR}/generated"
PAYLOAD_GEN_INDEX="${PAYLOAD_DIR}/generated.index"   # backend|template|ts|domains_mode|domains_list

payload_save_generated() {
  local backend="$1" tid="$2" domains_mode="$3" domains_list="$4" payload="$5"
  mkdir -p "$PAYLOAD_GEN_DIR" >/dev/null 2>&1 || true
  printf "%s\n" "$payload" > "${PAYLOAD_GEN_DIR}/${backend}.txt" 2>/dev/null || true

  [[ -f "$PAYLOAD_GEN_INDEX" ]] || : > "$PAYLOAD_GEN_INDEX"
  local ts; ts="$(date +%s)"
  awk -F'|' -v b="$backend" 'BEGIN{OFS="|"} $1!=b{print}' "$PAYLOAD_GEN_INDEX" 2>/dev/null > "${PAYLOAD_GEN_INDEX}.tmp" || true
  printf "%s|%s|%s|%s|%s\n" "$backend" "$tid" "$ts" "$domains_mode" "$domains_list" >> "${PAYLOAD_GEN_INDEX}.tmp"
  mv "${PAYLOAD_GEN_INDEX}.tmp" "$PAYLOAD_GEN_INDEX" 2>/dev/null || true
}

payload_list_generated() {
  local O; O="$(payload_out)"
  mapfile -t lines < <(backend_lines)
  if [[ ${#lines[@]} -eq 0 ]]; then
    echo -e "${YLW}No hay backends cargados.${NC}" >"$O"
    return 0
  fi

  echo -e "${CYA}Payloads guardados por backend (backend → fecha):${NC}" >"$O"
  local i=0 key url ipport ip port f ts info
  for line in "${lines[@]}"; do
    i=$((i+1))
    key="$(echo "$line" | sed -E 's/^\s*"([^"]+)".*/\1/')"
    url="$(echo "$line" | sed -E 's/^.*"\s+"([^"]+)";\s*$/\1/')"
    ipport="${url#http://}"; ip="${ipport%%:*}"; port="${ipport##*:}"

    f="${PAYLOAD_GEN_DIR}/${key}.txt"
    if [[ -s "$f" ]]; then
      ts="$(stat -c %Y "$f" 2>/dev/null || echo 0)"
      ts="$(date -d "@$ts" "+%Y-%m-%d %H:%M" 2>/dev/null || echo "-")"
      info="${GRN}SI${NC} → ${WHT}${ts}${NC}"
    else
      info="${DIM}NO${NC}"
    fi

    printf " %3s) %-20s -> %s:%s   %s\n" "$i" "$key" "$ip" "$port" "$info" >"$O"
  done
  echo >"$O"
}


payload_view_generated() {
  local O; O="$(payload_out)"
  payload_list_generated
  local n
  if [[ -r /dev/tty ]]; then
    read -r -p "Número de backend: " n </dev/tty
  else
    read -r -p "Número de backend: " n
  fi
  [[ "$n" =~ ^[0-9]+$ ]] || { echo -e "${YLW}Inválido.${NC}" >"$O"; return 0; }
  mapfile -t lines < <(backend_lines)
  (( n>=1 && n<=${#lines[@]} )) || { echo -e "${YLW}Fuera de rango.${NC}" >"$O"; return 0; }
  local key
  key="$(echo "${lines[$((n-1))]}" | sed -E 's/^\s*"([^"]+)".*/\1/')"
  if [[ ! -s "${PAYLOAD_GEN_DIR}/${key}.txt" ]]; then
    echo -e "${YLW}Ese backend no tiene payload guardado.${NC}" >"$O"
    return 0
  fi
  echo -e "${GRN}✅ Payload guardado para:${NC} $key" >"$O"
