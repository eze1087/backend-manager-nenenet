traffic_show_from_db() {
  local mode="$1" # ip|backend
  local limit="${2:-50}"
  local db="/var/lib/backendmgr/traffic_totals_backend.db"
  [[ "$mode" == "ip" ]] && db="/var/lib/backendmgr/traffic_totals_ip.db"

  [[ -f "$db" ]] || { echo -e "${YLW}No hay resumen todavía (db vacío). Esperá 1 ciclo del scanner.${NC}"; return 0; }

  # Mapa backend -> ip:port (desde backends.map)
  local map_tmp=""
  if [[ "$mode" != "ip" ]]; then
    map_tmp="$(mktemp)"
    awk '
      match($0, /"([^"]+)"[ \t]+"http:\/\/([^"]+)"/, m) { print m[1] "\t" m[2] }
    ' "$NGX_BACKENDS_MAP" 2>/dev/null | sort -u > "$map_tmp" || true
  fi

  if [[ "$mode" == "ip" ]]; then
    printf "%-18s %-12s %-12s %-12s %-10s\n" "IP" "DOWN" "UP" "TOTAL" "REQ"
    echo "--------------------------------------------------------------------------"
  else
    printf "%-22s %-18s %-12s %-12s %-12s %-10s\n" "BACKEND" "IP:PORT" "DOWN" "UP" "TOTAL" "REQ"
    echo "------------------------------------------------------------------------------------------------"
  fi

  awk -v mode="$mode" -v MAP="$map_tmp" '
    BEGIN{
      FS="[\t|]"; OFS="\t";
      if(mode!="ip" && MAP!=""){
        while((getline line < MAP)>0){
          split(line,a,"\t");
          if(a[1]!="") mp[a[1]]=a[2];
        }
        close(MAP);
      }
    }
    function human(bytes, mb, out){
      mb=bytes/1024/1024;
      if(mb>=1024) out=sprintf("%.2f GB", mb/1024);
      else out=sprintf("%.2f MB", mb);
      return out;
    }
    NF>=3{
      k=$1; gsub(/\r/,"",k);
      sub(/^[[:space:]]+/,"",k); sub(/[[:space:]]+$/,"",k);
      if(k=="") next;

      # DB formatos soportados:
      #  - key total down up req
      #  - key down up req
      #  - key total req
      total=0; down=0; up=0; req=0;
      if(NF>=5){
        total=$2+0; down=$3+0; up=$4+0; req=$5+0;
      } else if(NF==4){
        down=$2+0; up=$3+0; req=$4+0; total=down+up;
      } else if(NF==3){
        total=$2+0; down=total; up=0; req=$3+0;
      } else {
        next;
      }

      if(mode=="ip"){
        printf "%-18s %-12s %-12s %-12s %-10d\n", k, human(down), human(up), human(total), req;
      } else {
        ipport=(k in mp)? mp[k] : "-";
        printf "%-22s %-18s %-12s %-12s %-12s %-10d\n", k, ipport, human(down), human(up), human(total), req;
      }
    }
  ' "$db" 2>/dev/null | head -n "$limit" || true

  [[ -n "$map_tmp" ]] && rm -f "$map_tmp" 2>/dev/null || true
  return 0
}

traffic_live_monitor() {
  local mode="${1:-backend}"  # backend|ip
  local refresh="${2:-2}"     # segundos
  local top="${3:-30}"        # filas

  [[ "$mode" == "backend" || "$mode" == "ip" ]] || mode="backend"
  [[ "$refresh" =~ ^[0-9]+$ ]] || refresh=2
  [[ "$top" =~ ^[0-9]+$ ]] || top=30
  (( refresh < 1 )) && refresh=1
  (( top < 5 )) && top=5
  (( top > 100 )) && top=100

  local key=""
  while true; do
    clear || true
    echo -e "${CYA}📺 Monitor en vivo de tráfico${NC}  ${DIM}(modo=${mode} • refresh=${refresh}s • top=${top})${NC}"
    echo -e "${DIM}Tip:${NC} presioná ${WHT}q${NC} para salir.\n"
    traffic_show_from_db "$mode" "$top"
    echo

    key=""
    if [[ -r /dev/tty ]]; then
      # espera refresh segundos o tecla
      IFS= read -rsn1 -t "$refresh" key </dev/tty || true
    else
      sleep "$refresh" || true
    fi
    [[ "${key,,}" == "q" ]] && break
  done
  return 0
}




