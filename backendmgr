payload_generate() {
  payload_init_defaults
  local O; O="$(payload_out)"
  echo -e "${CYA}Generar payload${NC}" >"$O"
  echo -e "${DIM}Primero elegís la plantilla, luego el backend de tu lista.${NC}\n" >"$O"

  local tid backend tpl out dom_choice dom_list dom_rot domains_mode

  # 1) Plantilla (muestra lista y selecciona)
  if ! payload_pick_template_id tid; then
    return 0
  fi

  # Validar plantilla ANTES de pedir backend (evita confusión)
  tpl="$(cat "$(payload_tpl_file "$tid")" 2>/dev/null || true)"
  if [[ -z "${tpl//[[:space:]]/}" ]]; then
    echo -e "${YLW}Plantilla vacía.${NC}" >"$O"
    return 0
  fi

  # 2) Backend (muestra lista y selecciona)
  if ! payload_pick_backend_key backend; then
    return 0
  fi

  # 3) Dominios madre
  local current_auto current_override
  current_auto="$(payload_domains_from_panel | paste -sd';' -)"
  current_override=""
  if [[ -s "$PAYLOAD_DOMAINS_FILE" ]]; then
    current_override="$(payload_domains_join_semicolon)"
  fi
  [[ -z "$current_auto" ]] && current_auto="(no configurado)"
  [[ -z "$current_override" ]] && current_override="(no override)"

  echo -e "\n${CYA}Dominios madre para Host:${NC}" >"$O"
  echo -e "${DIM}1) Usar dominios del panel (Dominios madre)\n2) Usar override guardado (si existe)\n3) Manual (solo este payload)\n4) Manual y guardar override${NC}\n" >"$O"
  echo -e "Auto: ${GRN}${current_auto}${NC}" >"$O"
  echo -e "Override: ${GRN}${current_override}${NC}\n" >"$O"

  if [[ -r /dev/tty ]]; then
    read -r -p "Opción (1-4) [1]: " dom_choice </dev/tty
  else
    read -r -p "Opción (1-4) [1]: " dom_choice
  fi
  dom_choice="${dom_choice:-1}"

  case "$dom_choice" in
    2)
      domains_mode="override"
      dom_list="$(payload_domains_join_semicolon)"
      [[ -z "$dom_list" ]] && { domains_mode="auto"; dom_list="$(payload_domains_from_panel | paste -sd';' -)"; }
      ;;
    3|4)
      if [[ -r /dev/tty ]]; then
        read -r -p "Pegá dominios separados por ; : " dom_list </dev/tty
      else
        read -r -p "Pegá dominios separados por ; : " dom_list
      fi
      dom_list="${dom_list// /}"
      [[ -z "$dom_list" ]] && { echo -e "${YLW}Sin dominios, uso auto.${NC}" >"$O"; domains_mode="auto"; dom_list="$(payload_domains_from_panel | paste -sd';' -)"; }
      if [[ "$dom_choice" == "4" ]]; then
        mkdir -p "$PAYLOAD_DIR" >/dev/null 2>&1 || true
        : > "$PAYLOAD_DOMAINS_FILE"
        IFS=";" read -r -a parts <<< "$dom_list"
        for part in "${parts[@]}"; do
          part="${part// /}"
          [[ -z "$part" ]] && continue
          echo "$part" >> "$PAYLOAD_DOMAINS_FILE"
        done
        domains_mode="manual_saved"
      else
        domains_mode="manual"
      fi
      ;;
    *)
      domains_mode="auto"
      dom_list="$(payload_domains_from_panel | paste -sd';' -)"
      ;;
  esac

  dom_list="${dom_list// /}"
  dom_rot="[rotate=${dom_list}]"

  echo >"$O"
  echo -e "${GRN}✅ Payload generado:${NC} (tpl=${tid} | backend=${backend})" >"$O"
  out="$(payload_render "$tpl" "$backend" "$dom_list" "$dom_rot")"
  payload_print_block "$out"

  mkdir -p "$PAYLOAD_DIR" >/dev/null 2>&1 || true
  printf "%s\n" "$out" > "$PAYLOAD_LAST_FILE" 2>/dev/null || true

  payload_save_generated "$backend" "$tid" "$domains_mode" "$dom_list" "$out" >/dev/null 2>&1 || true

  echo -e "${DIM}Tip:${NC} Copiá SOLO lo que está entre [START_PAYLOAD] y [END_PAYLOAD]." >"$O"
  echo -e "${DIM}Guardado también para ese backend (Payloads → Ver guardados).${NC}" >"$O"
  return 0
}

