  key="$(echo "${lines[$((n-1))]}" | sed -E 's/^\s*"([^"]+)".*/\1/')"
  rm -f "${PAYLOAD_GEN_DIR}/${key}.txt" 2>/dev/null || true
  awk -F'|' -v b="$key" 'BEGIN{OFS="|"} $1!=b{print}' "$PAYLOAD_GEN_INDEX" 2>/dev/null > "${PAYLOAD_GEN_INDEX}.tmp" || true
