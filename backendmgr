restore_nginx_binary(){
  local SBIN="/usr/sbin/nginx"
  local REAL="/usr/sbin/nginx.real"

  have_systemd && systemctl stop nginx >/dev/null 2>&1 || true

  if [[ -x "$REAL" ]]; then
    rm -f "$SBIN" 2>/dev/null || true
    mv "$REAL" "$SBIN" 2>/dev/null || true
    chmod 755 "$SBIN" 2>/dev/null || true
  fi

  rm -f /usr/local/bin/nginx /usr/bin/nginx 2>/dev/null || true
}


    
ensure_nginx_wrapper_quiet_on_success() {
  # ✅ FIX definitivo:
  # El wrapper se rompía porque el patch anterior usaba regex y podía cortar run_panel() a la mitad,
  # dejando un nginx inválido (syntax error).
  # Acá NO parchamos con regex: re-escribimos el wrapper completo y sano.
  local MAIN="/usr/sbin/nginx"
  local REAL="/usr/sbin/nginx.real"
  local TS; TS="$(date +%F_%H%M%S)"

  # Solo actuar si esto ES un wrapper (o si existe nginx.real, señal de wrapper instalado)
  if [[ -x "$REAL" ]] || ( [[ -f "$MAIN" ]] && grep -q "backendmgr.wrapper.log" "$MAIN" 2>/dev/null ); then
    local BAK="${MAIN}.bak.${TS}"
    [[ -f "$MAIN" ]] && cp -a "$MAIN" "$BAK" 2>/dev/null || true

    cat > "$MAIN" <<'WRAP'
#!/usr/bin/env bash
set -euo pipefail

# === BACKENDMGR WRAPPER (SAFE) ===
# - Sin args: abre el panel
# - Con args: ejecuta nginx real (sin recursión)
PANEL="/usr/local/bin/backendmgr"
LOG="/var/log/backendmgr.wrapper.log"

log() {
  mkdir -p /var/log 2>/dev/null || true
  printf "[%s] %s\n" "$(date +%F\ %T)" "$*" >>"$LOG" 2>/dev/null || true
}

run_panel() {
  local rc=0
  log "RUN_PANEL user=$(id -u) tty=$(tty 2>/dev/null || echo none) cwd=$(pwd)"

  if [[ ! -x "$PANEL" ]]; then
    log "ERROR panel not executable: $PANEL"
    if [[ -r /dev/tty && -w /dev/tty ]]; then
      echo "ERROR: no existe o no es ejecutable: $PANEL" >/dev/tty
    else
      echo "ERROR: no existe o no es ejecutable: $PANEL" >&2
    fi
    return 127
  fi

  set +e
  if [[ -r /dev/tty && -w /dev/tty ]]; then
    </dev/tty >/dev/tty 2>&1 "$PANEL"
    rc=$?
  else
    "$PANEL"
    rc=$?
  fi
  set -e

  log "PANEL_EXIT rc=$rc"

  # Solo avisar si hubo error (rc != 0)
  if [[ "$rc" -ne 0 && -r /dev/tty && -w /dev/tty ]]; then
    echo "" >/dev/tty
    echo "⚠️ El panel terminó (rc=$rc). Log: $LOG" >/dev/tty
    read -r -p "Enter para volver..." _ </dev/tty || true
  fi

  return "$rc"
}

# Sin args -> panel
if [[ $# -eq 0 ]]; then
  run_panel
  exit $?
fi

# Alias explícitos
case "${1:-}" in
  menu|panel|nenenet)
    run_panel
    exit $?
  ;;
esac

# Con args -> nginx real (evitar loop si /usr/bin/nginx o /usr/local/bin/nginx son symlinks al wrapper)
SELF="$(readlink -f "$0" 2>/dev/null || echo "$0")"
for CAND in /usr/sbin/nginx.real /usr/bin/nginx /bin/nginx; do
  [[ -x "$CAND" ]] || continue
  REALPATH="$(readlink -f "$CAND" 2>/dev/null || echo "$CAND")"
  [[ "$REALPATH" == "$SELF" ]] && continue
  exec "$REALPATH" "$@"
done

log "ERROR real nginx missing (args=$*)"
echo "ERROR: nginx real no encontrado (esperado /usr/sbin/nginx.real)." >&2
exit 127
WRAP

    chmod 755 "$MAIN" 2>/dev/null || true

    # Validación: si quedó inválido, volvemos al backup
    if ! bash -n "$MAIN" >/dev/null 2>&1; then
      [[ -f "$BAK" ]] && mv -f "$BAK" "$MAIN" 2>/dev/null || true
    fi
  fi

  # Asegurar que nginx en PATH apunte al wrapper principal
  if [[ -f "$MAIN" ]]; then
    for p in /usr/local/bin/nginx /usr/bin/nginx; do
      if [[ -e "$p" && ! -L "$p" ]]; then
        cp -a "$p" "${p}.bak.${TS}" 2>/dev/null || true
        rm -f "$p" 2>/dev/null || true
      fi
      ln -sf "$MAIN" "$p" 2>/dev/null || true
    done
  fi
}


uninstall_backendmgr(){
  echo -e "${RED}🗑️  DESINSTALAR Backend Manager${NC}"
  echo -e "${DIM}Esto elimina panel, configs, estado, timers y restaura /usr/sbin/nginx real.${NC}"
  echo
  read -r -p "Confirmar desinstalación TOTAL (s/N): " yn
  case "${yn,,}" in
    s|si|sí|y|yes) ;;
    *) echo -e "${YLW}Cancelado.${NC}"; return 0 ;;
  esac

  echo
  echo "[1/6] Deteniendo timers/servicios..."
  cleanup_systemd

  echo "[2/6] Restaurando nginx (quitando wrapper si existía)..."
  restore_nginx_binary

  echo "[3/6] Removiendo panel..."
  rm -f /usr/local/bin/backendmgr 2>/dev/null || true

  echo "[4/6] Removiendo configs..."
  rm -rf /etc/backendmgr 2>/dev/null || true
  rm -rf /etc/nginx/conf.d/backendmgr 2>/dev/null || true

  echo "[5/6] Removiendo estado y logs..."
  rm -rf /var/lib/backendmgr 2>/dev/null || true
  rm -f /var/log/backendmgr.panel.log /var/log/backendmgr.wrapper.log 2>/dev/null || true

  echo "[6/6] Removiendo backups..."
  rm -rf /etc/nginx/backendmgr-backups 2>/dev/null || true

  echo
  echo -e "${GRN}✅ Listo. Backend Manager fue removido.${NC}"
  echo -e "${DIM}Si querés desinstalar dependencias (nginx/jq/etc.), hacelo manualmente.${NC}"
  echo
  exit 0
}

