payload_delete_generated() {
  local O; O="$(payload_out)"
  payload_list_generated
  local n
  if [[ -r /dev/tty ]]; then
    read -r -p "Número de backend a borrar payload: " n </dev/tty
  else
    read -r -p "Número de backend a borrar payload: " n
  fi
  [[ "$n" =~ ^[0-9]+$ ]] || { echo -e "${YLW}Inválido.${NC}" >"$O"; return 0; }
  mapfile -t lines < <(backend_lines)
  (( n>=1 && n<=${#lines[@]} )) || { echo -e "${YLW}Fuera de rango.${NC}" >"$O"; return 0; }
