  echo
  return 0
}

# ------------------ TRÁFICO (IP / BACKEND) ------------------
traffic_stats() {
  read_cfg

  # Auto-upgrade del formato de logging (para medir UP/DOWN de forma más precisa)
  if [[ -f "$NGX_LOGGING_SNIP" ]] && ! grep -q '\$request_length' "$NGX_LOGGING_SNIP" 2>/dev/null; then
    echo -e "${YLW}⚙️ Actualizando formato de logging de tráfico (UP/DOWN)...${NC}"
    cat > "$NGX_LOGGING_SNIP" <<'EOF'
log_format backendmgr_stats '$time_local|$remote_addr|$host|$http_backend|$upstream_addr|$status|$body_bytes_sent|$request_length|$upstream_bytes_sent|$upstream_bytes_received|$request_time|$upstream_response_time|$request';
EOF
    nginx_test_reload
    read_cfg
  fi

  echo -e "${CYA}Tráfico (por IP o Backend)${NC}"
  echo -e "${DIM}Archivo: ${STATS_LOG}${NC}"
  if [[ "${TRAFFIC_STATS_ENABLED}" == "true" ]]; then
    if [[ -n "${TRAFFIC_STATS_SINCE}" ]]; then
      echo -e "${GRN}Logging: ACTIVADO${NC} (desde ${TRAFFIC_STATS_SINCE})"
    else
      echo -e "${GRN}Logging: ACTIVADO${NC}"
    fi
  else
    echo -e "${YLW}Logging: DESACTIVADO${NC}"
  fi

  if [[ "${TRAFFIC_SCAN_ENABLED}" == "true" ]]; then
    echo -e "${GRN}Scanner: ACTIVADO${NC} (modo=${TRAFFIC_SCAN_MODE}, cada ${TRAFFIC_SCAN_INTERVAL})"
  else
    echo -e "${YLW}Scanner: DESACTIVADO${NC}"
  fi
  echo

  echo "1) Por IP"
  echo "2) Por Backend (header)"
  echo "3) Activar logging de tráfico (stats)"
  echo "4) Desactivar logging de tráfico (stats)"
  echo "5) ⚙️  Escaneo permanente (scanner): menú"
  echo "6) 📌 Totales acumulados (recalcular y mostrar)"
  echo "7) 🧹 Borrar historial del scanner (acumulado)"
  echo "8) 📺 Monitor en vivo (lista actualizable)"
  echo "0) Volver"
  read -r -p "Opción: " op
  echo

  case "$op" in
    0) return 0 ;;
    3)
      if [[ "${TRAFFIC_STATS_ENABLED}" == "true" ]]; then
        echo -e "${YLW}Ya está activado.${NC} ${DIM}(reaplicando)${NC}"
      fi
      set_traffic_stats_enabled true
      echo -e "${GRN}✅ Logging activado.${NC}"
      echo -e "${DIM}Archivo:${NC} ${STATS_LOG}"
      return 0
      ;;
    4)
      if [[ "${TRAFFIC_STATS_ENABLED}" != "true" ]]; then
        echo -e "${YLW}Ya está desactivado.${NC} ${DIM}(reaplicando)${NC}"
      fi
      set_traffic_stats_enabled false
      echo -e "${GRN}✅ Logging desactivado.${NC}"
      return 0
      ;;
    5)
      traffic_scan_menu
      return 0
      ;;
    6)
      echo -e "${CYA}Totales acumulados (usa todo el log y actualiza DB)${NC}"
      echo "1) Por IP"
      echo "2) Por Backend (header)"
      read -r -p "Opción: " which
      case "$which" in
        1) traffic_scan_run_now "ip"; echo; traffic_show_from_db "ip" ;;
        2) traffic_scan_run_now "backend"; echo; traffic_show_from_db "backend" ;;
        *) echo -e "${YLW}Opción inválida.${NC}" ;;
      esac
      return 0
      ;;

    7)
      traffic_scan_clear_history
      return 0
      ;;

    8)
      echo -e "${CYA}Monitor en vivo${NC}"
      echo "1) Por IP"
      echo "2) Por Backend (header)"
      read -r -p "Opción [2]: " w
      w="${w:-2}"
      local mode="backend"
      [[ "$w" == "1" ]] && mode="ip"
      read -r -p "Refresh cada cuántos segundos (Enter=2): " rs
      rs="${rs:-2}"
      read -r -p "Mostrar cuántas filas (Enter=30): " top
      top="${top:-30}"
      traffic_live_monitor "$mode" "$rs" "$top"
      return 0
      ;;

    1|2)
      # Si scanner activo: mostramos del DB (si existe). Si no: fallback al tail.
      if [[ "${TRAFFIC_SCAN_ENABLED}" == "true" ]]; then
        if [[ "$op" == "1" ]]; then
          echo -e "${DIM}Mostrando desde resumen del scanner (acumulado).${NC}\n"
          traffic_show_from_db "ip"
        else
          echo -e "${DIM}Mostrando desde resumen del scanner (acumulado).${NC}\n"
          traffic_show_from_db "backend"
        fi
        return 0
      fi

      [[ -f "$STATS_LOG" ]] || { echo -e "${YLW}No existe todavía: ${STATS_LOG}${NC}"; return 0; }

      local lines=5000
      read -r -p "Cantidad de líneas a analizar (Enter=${lines}): " in
      lines="${in:-$lines}"
      echo

      if [[ "$op" == "1" ]]; then
        printf "%-18s %-12s %-10s\n" "IP" "TOTAL(MB)" "REQ"
        echo "---------------------------------------------"
        ( set +o pipefail;
        tail -n "$lines" "$STATS_LOG" | awk -F'|' '
          {ip=$2; bytes=$7; req[ip]+=1; b[ip]+=bytes}
          END{
            for(i in b){
              mb=b[i]/1024/1024;
              printf "%-18s %-12.2f %-10d\n", i, mb, req[i]
            }
          }' | sort -k2 -nr | head -n 30 ) || true
      else
        printf "%-22s %-12s %-10s\n" "BACKEND" "TOTAL(MB)" "REQ"
        echo "---------------------------------------------------"
        ( set +o pipefail;
        tail -n "$lines" "$STATS_LOG" | awk -F'|' '
          {be=$4; if(be=="") be="(vacío)"; bytes=$7; req[be]+=1; b[be]+=bytes}
          END{
            for(i in b){
              mb=b[i]/1024/1024;
              printf "%-22s %-12.2f %-10d\n", i, mb, req[i]
            }
          }' | sort -k2 -nr | head -n 30 ) || true
      fi

      return 0
      ;;
    *) echo "Opción inválida"; return 0 ;;
  esac
}

