# ------------------ FIREWALL UFW ------------------
ufw_open_port() {
  echo -e "${CYA}Firewall UFW: permitir tráfico por puerto${NC}"
  echo -e "${DIM}Ejemplo: 80/tcp (HTTP) o 443/tcp (HTTPS).${NC}\n"

  command -v ufw >/dev/null 2>&1 || { echo -e "${YLW}UFW no está instalado. Instalalo con: apt install -y ufw${NC}"; return 0; }

  ufw status || true
  echo

  read -r -p "Puerto a habilitar (ej: 80 o 443): " port
  [[ "$port" =~ ^[0-9]{2,5}$ ]] || { echo -e "${RED}Puerto inválido.${NC}"; return 0; }

  ufw allow "${port}/tcp" || true
  [[ "$port" == "80" ]] && ufw allow 'Nginx HTTP' || true
  [[ "$port" == "443" ]] && ufw allow 'Nginx Full' || true
  ufw reload || true

  echo -e "${GRN}✅ Regla aplicada.${NC}"
  ufw status || true
  return 0
}

# ------------------ BACKUP / RESTORE ------------------
backup_bundle() {
  mkdir -p "$BACKUP_DIR"
  local out="${BACKUP_DIR}/bundle-$(date +%Y%m%d-%H%M%S).tar.gz"
  tar -czf "$out" \
    --exclude="/var/lib/backendmgr/traffic_*" \
    --exclude="/var/lib/backendmgr/*traffic*" \
    --exclude="/var/lib/backendmgr/*scanner*" \
    /etc/nginx/nginx.conf \
    /etc/nginx/conf.d/backendmgr \
    /etc/backendmgr \
    /var/lib/backendmgr 2>/dev/null || true
  echo -e "${GRN}✅ Backup creado:${NC} $out"
  return 0
}

restore_bundle() {
  echo -e "${CYA}Restaurar backup${NC}"
  ls -1t "${BACKUP_DIR}"/bundle-*.tar.gz 2>/dev/null | nl -w2 -s') ' || { echo "No hay backups."; return 0; }
  read -r -p "Número: " n
  file="$(ls -1t "${BACKUP_DIR}"/bundle-*.tar.gz 2>/dev/null | sed -n "${n}p")"
  [[ -n "${file:-}" ]] || { echo -e "${YLW}Selección inválida.${NC}"; return 0; }

  echo -e "${YLW}⚠️ Backup preventivo antes de restaurar...${NC}"
  backup_bundle

  echo -e "${DIM}Extrayendo:${NC} $file"
  # --overwrite para que pise configs existentes (restauración real)
  if ! tar -xzf "$file" -C / --overwrite 2>/dev/null; then
    echo -e "${RED}ERROR:${NC} No pude extraer el backup. (archivo corrupto o permisos)"
    return 0
  fi

  # Re-armar includes/snippets por si el backup viene de otra versión
  ensure_http_conf_maps
  ensure_mothers_include
  write_apply_conf
  rebuild_balancer_files
  rebuild_mothers_upstreams || true

  local ngx
  ngx="$(nginx_real_bin)"

  # Reload/restart nginx (automático)
  if command -v systemctl >/dev/null 2>&1; then
    if "$ngx" -t >/dev/null 2>&1; then
      systemctl reload nginx >/dev/null 2>&1 || systemctl restart nginx >/dev/null 2>&1 || true
    else
      systemctl restart nginx >/dev/null 2>&1 || true
    fi
  else
    nginx_test_reload
  fi

  echo -e "${GRN}✅ Restaurado y recargado Nginx.${NC}"
  return 0
}

backup_restore_menu() {
  while true; do
    echo -e "${CYA}💾 Backup y restauración${NC}"
    echo -e "${DIM}Backups en: ${BACKUP_DIR}${NC}
"
    echo "1) Crear backup (bundle)"
    echo "2) Restaurar backup (elegir de lista)"
    echo "3) Listar backups"
    echo "0) Volver"
    read -r -p "Opción: " op
    echo
    case "$op" in
      1) backup_bundle; pause ;;
      2) restore_bundle; pause ;;
      3) ls -1t "${BACKUP_DIR}"/bundle-*.tar.gz 2>/dev/null | nl -w2 -s') ' || echo "No hay backups."; pause ;;
      0) return 0 ;;
      *) echo -e "${YLW}Opción inválida.${NC}"; pause ;;
    esac
  done
}

