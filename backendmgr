# ------------------ PICKS ------------------
pick_domain() {
  mapfile -t files < <(server_files)
  [[ "${#files[@]}" -gt 0 ]] || { echo -e "${YLW}No hay dominios creados.${NC}"; return 1; }
  echo -e "${CYA}Elegir dominio madre:${NC}"
  local i=0
  for f in "${files[@]}"; do
    i=$((i+1))
    dom="$(grep -E '^\s*server_name\s+' "$f" | head -n1 | sed -E 's/^\s*server_name\s+([^;]+);.*/\1/' || true)"
    printf "%-3s) %s\n" "$i" "$dom"
  done
  echo
  read -r -p "Número: " n
  [[ "$n" =~ ^[0-9]+$ ]] || return 1
  (( n>=1 && n<=${#files[@]} )) || return 1
  PICKED_DOMAIN_FILE="${files[$((n-1))]}"
  PICKED_DOMAIN="$(grep -E '^\s*server_name\s+' "$PICKED_DOMAIN_FILE" | head -n1 | sed -E 's/^\s*server_name\s+([^;]+);.*/\1/' || true)"
  [[ -n "${PICKED_DOMAIN:-}" ]] || return 1
  return 0
}

pick_backend() {
  mapfile -t lines < <(backend_lines)
  [[ "${#lines[@]}" -gt 0 ]] || { echo -e "${YLW}No hay backends.${NC}"; return 1; }
  echo -e "${CYA}Elegir backend:${NC}"
  local i=0
  for line in "${lines[@]}"; do
    i=$((i+1))
    key="$(echo "$line" | sed -E 's/^\s*"([^"]+)".*$/\1/')"
    url="$(echo "$line" | sed -E 's/^.*"\s+"([^"]+)";\s*$/\1/')"
    ipport="${url#http://}"; ip="${ipport%%:*}"; port="${ipport##*:}"
    printf "%-3s) %-20s -> %s:%s\n" "$i" "$key" "$ip" "$port"
  done
  echo
  read -r -p "Número: " n
  [[ "$n" =~ ^[0-9]+$ ]] || return 1
  (( n>=1 && n<=${#lines[@]} )) || return 1
  line="${lines[$((n-1))]}"
  PICKED_BACKEND="$(echo "$line" | sed -E 's/^\s*"([^"]+)".*$/\1/')"
  PICKED_BACKEND_URL="$(echo "$line" | sed -E 's/^.*"\s+"([^"]+)";\s*$/\1/')"
  return 0
}

# ------------------ DOMINIOS / SERVERS ------------------
create_server_for_domain() {
  local dom="$1"
  local file="${SERVERS_DIR}/${dom}.conf"
  local safe="${dom//./_}"

  local cto="${2:-300s}"
  local sto="${3:-600s}"
  local rto="${4:-600s}"

  cat > "$file" <<EOF
server {
    listen 80;
    listen [::]:80;

    server_name ${dom};

    access_log /var/log/nginx/${safe}.access.log;
    error_log  /var/log/nginx/${safe}.error.log;

    # Opcional: timeouts largos para backend
    proxy_connect_timeout ${cto};
    proxy_send_timeout    ${sto};
    proxy_read_timeout    ${rto};

    location / {
        include /etc/nginx/conf.d/backendmgr/targets/${dom}.conf;

        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;

        include /etc/nginx/conf.d/backendmgr/apply.conf;
    }
}
EOF
}

add_domain_auto_create() {
  echo -e "${CYA}Agregar dominio madre (AUTO crea server)${NC}"
  echo -e "${DIM}Ejemplo: cpu2.nenenet.site${NC}\n"
  read -r -p "Dominio madre nuevo: " dom
  validate_domain "$dom" || { echo -e "${RED}Dominio inválido.${NC}"; return 0; }

  create_server_for_domain "$dom" "300s" "600s" "600s"

  # Si no hay primary_domain, seteamos este como principal
  if [[ -f "$CFG_FILE" ]]; then
    curpd="$(jq -r '.primary_domain // ""' "$CFG_FILE" 2>/dev/null || echo "")"
    [[ "$curpd" == "null" ]] && curpd=""
    if [[ -z "$curpd" ]]; then
      jq --arg d "$dom" '.primary_domain = $d' "$CFG_FILE" > "${CFG_FILE}.tmp" && mv "${CFG_FILE}.tmp" "$CFG_FILE"
    fi
  fi
  ensure_http_conf_maps
  ensure_mothers_include
  write_apply_conf
  rebuild_balancer_files
  ensure_domain_target_exists "$dom"
  nginx_test_reload
  echo -e "${GRN}✅ Dominio madre creado:${NC} ${dom} (80)"
  return 0
}

create_or_edit_server_http() {
  echo -e "${CYA}Editar dominio madre (timeouts)${NC}"
  echo -e "${DIM}Enter = default 300/600/600.${NC}\n"

  read -r -p "Dominio (ej: cpu2.elnene.site): " dom
  validate_domain "$dom" || { echo -e "${RED}Dominio inválido.${NC}"; return 0; }

  read -r -p "proxy_connect_timeout (Enter=300s): " cto
  read -r -p "proxy_send_timeout    (Enter=600s): " sto
  read -r -p "proxy_read_timeout    (Enter=600s): " rto
  cto="${cto:-300s}"; sto="${sto:-600s}"; rto="${rto:-600s}"

  create_server_for_domain "$dom" "$cto" "$sto" "$rto"
  ensure_http_conf_maps
  ensure_mothers_include
  write_apply_conf
  rebuild_balancer_files
  ensure_domain_target_exists "$dom"
  nginx_test_reload
  echo -e "${GRN}✅ Actualizado:${NC} ${dom}"
  return 0
}

list_domains() {
  echo -e "${CYA}Dominios madre (servers)${NC}\n"
  mapfile -t files < <(server_files)
  [[ "${#files[@]}" -gt 0 ]] || { echo -e "${YLW}No hay dominios creados.${NC}"; return 0; }

  local idx=0
  for f in "${files[@]}"; do
    idx=$((idx+1))
    dom="$(grep -E '^\s*server_name\s+' "$f" | head -n1 | sed -E 's/^\s*server_name\s+([^;]+);.*/\1/')"
    echo "$idx) $dom"
  done
  return 0
}

# ---- gestión de dominios madre (editar/eliminar) ----
pick_domain_for_manage() {
  mapfile -t files < <(server_files)
  [[ "${#files[@]}" -gt 0 ]] || { echo -e "${YLW}No hay dominios madre creados.${NC}"; return 1; }

  echo -e "${CYA}Elegir dominio madre:${NC}"
  local i=0
  for f in "${files[@]}"; do
    i=$((i+1))
    dom="$(grep -E '^\s*server_name\s+' "$f" | head -n1 | sed -E 's/^\s*server_name\s+([^;]+);.*/\1/' || true)"
    printf "%-3s) %s\n" "$i" "$dom"
  done
  echo
  read -r -p "Número: " n
  [[ "$n" =~ ^[0-9]+$ ]] || return 1
  (( n>=1 && n<=${#files[@]} )) || return 1

  PICKED_DOMAIN_FILE="${files[$((n-1))]}"
  PICKED_DOMAIN="$(grep -E '^\s*server_name\s+' "$PICKED_DOMAIN_FILE" | head -n1 | sed -E 's/^\s*server_name\s+([^;]+);.*/\1/' || true)"
  [[ -n "${PICKED_DOMAIN:-}" ]] || return 1
  return 0
}

edit_domain_pick() {
  echo -e "${CYA}Editar dominio madre (timeouts)${NC}"
  echo -e "${DIM}Elegís un dominio de la lista. Enter = default 300/600/600.${NC}\n"

  pick_domain_for_manage || return 0

  read -r -p "proxy_connect_timeout (Enter=300s): " cto
  read -r -p "proxy_send_timeout    (Enter=600s): " sto
  read -r -p "proxy_read_timeout    (Enter=600s): " rto
  cto="${cto:-300s}"; sto="${sto:-600s}"; rto="${rto:-600s}"

  create_server_for_domain "$PICKED_DOMAIN" "$cto" "$sto" "$rto"

  ensure_http_conf_maps
  ensure_mothers_include
  write_apply_conf
  rebuild_balancer_files
  ensure_domain_target_exists "$PICKED_DOMAIN"
  nginx_test_reload

  echo -e "${GRN}✅ Dominio actualizado:${NC} ${PICKED_DOMAIN}"
  return 0
}

delete_domain_pick() {
  echo -e "${CYA}Eliminar dominio madre${NC}"
  echo -e "${DIM}Borra el server .conf del dominio (no toca backends).${NC}\n"

  pick_domain_for_manage || return 0

  echo -e "${YLW}Vas a eliminar:${NC} ${PICKED_DOMAIN}"
  read -r -p "Confirmar (s/N): " yn
  case "${yn,,}" in
    s|si|sí|y|yes) ;;
    *) echo -e "${YLW}Cancelado.${NC}"; return 0 ;;
  esac

  # Si eliminás el dominio que está como primary_domain, lo limpiamos del config
  if [[ -f "$CFG_FILE" ]]; then
    if [[ "$(jq -r '.primary_domain // ""' "$CFG_FILE" 2>/dev/null || echo "")" == "$PICKED_DOMAIN" ]]; then
      jq '.primary_domain = ""' "$CFG_FILE" > "${CFG_FILE}.tmp" && mv "${CFG_FILE}.tmp" "$CFG_FILE"
    fi
  fi

  rm -f "$PICKED_DOMAIN_FILE" || true
  rm -f "$(target_file "$PICKED_DOMAIN")" 2>/dev/null || true
  rm -f "$(mother_list_file "$PICKED_DOMAIN")" 2>/dev/null || true
  rm -f "$(mother_mode_file "$PICKED_DOMAIN")" 2>/dev/null || true

  rebuild_mothers_upstreams || true
  ensure_http_conf_maps
  ensure_mothers_include
  write_apply_conf
  rebuild_balancer_files
  nginx_test_reload

  echo -e "${GRN}✅ Dominio eliminado:${NC} ${PICKED_DOMAIN}"
  return 0
}

domains_menu() {
  while true; do
    echo -e "${CYA}Dominios madre${NC}"
    echo " 1) ➕ Agregar dominio madre (AUTO crea server)"
    echo " 2) ✏️  Editar dominio madre (elegir de lista)"
    echo " 3) 🗑️  Eliminar dominio madre (elegir de lista)"
    echo " 4) 📃 Listar dominios madre"
    echo " 0) Volver"
    echo
    read -r -p "Opción: " op
    echo
    case "$op" in
      1) add_domain_auto_create; pause ;;
      2) edit_domain_pick; pause ;;
      3) delete_domain_pick; pause ;;
      4) list_domains; pause ;;
      0) return 0 ;;
      *) echo -e "${YLW}Opción inválida.${NC}"; pause ;;
    esac
  done
}

# ------------------ BACKENDS ------------------

# ------------------ META BACKENDS (creación / expiración) ------------------
# Formato: key|ip|port|created_epoch|expires_epoch(0=sin vencimiento)
backend_meta_normalize() {
  [[ -f "$BACKEND_META_FILE" ]] || return 0
  awk -F'|' 'NF>=1 && $1!=""{a[$1]=$0} END{for(k in a) print a[k]}' "$BACKEND_META_FILE" \
    | sort > "${BACKEND_META_FILE}.tmp" 2>/dev/null || true
  mv -f "${BACKEND_META_FILE}.tmp" "$BACKEND_META_FILE" 2>/dev/null || true
}

backend_meta_get() {
  local k="$1"
  [[ -f "$BACKEND_META_FILE" ]] || return 1
  grep -E "^${k}\|" "$BACKEND_META_FILE" 2>/dev/null | tail -n 1
}

backend_meta_upsert() {
  local k="$1" ip="$2" port="$3" created="$4" expires="$5"
  mkdir -p "$STATE_DIR" 2>/dev/null || true
  [[ -f "$BACKEND_META_FILE" ]] || : > "$BACKEND_META_FILE"
  # remover vieja
  grep -v -E "^${k}\|" "$BACKEND_META_FILE" > "${BACKEND_META_FILE}.tmp" 2>/dev/null || true
  printf "%s|%s|%s|%s|%s\n" "$k" "$ip" "$port" "$created" "$expires" >> "${BACKEND_META_FILE}.tmp"
  mv -f "${BACKEND_META_FILE}.tmp" "$BACKEND_META_FILE"
  backend_meta_normalize
}

backend_meta_remove() {
  local k="$1"
  [[ -f "$BACKEND_META_FILE" ]] || return 0
  grep -v -E "^${k}\|" "$BACKEND_META_FILE" > "${BACKEND_META_FILE}.tmp" 2>/dev/null || true
  mv -f "${BACKEND_META_FILE}.tmp" "$BACKEND_META_FILE" 2>/dev/null || true
}

backend_fmt_date() {
  local epoch="$1"
  [[ -z "$epoch" || "$epoch" == "0" ]] && { echo "-"; return 0; }
  date -d "@$epoch" "+%Y-%m-%d" 2>/dev/null || echo "-"
}

backend_delete_by_key() {
  local key="$1"
  # busca línea exacta por key en backends.map y la elimina
  local line
  line="$(backend_lines | awk -v k="$key" '{
      match($0, /^[ \t]*"([^"]+)"/, m);
      if(m[1]==k){print; exit}
    }')"
  [[ -n "$line" ]] || return 1

  awk -v t="$line" '$0!=t{print}' "$NGX_BACKENDS_MAP" > "${NGX_BACKENDS_MAP}.tmp" || true
  mv "${NGX_BACKENDS_MAP}.tmp" "$NGX_BACKENDS_MAP"

  backend_meta_remove "$key"

  rebuild_balancer_files
  ensure_http_conf_maps
  ensure_mothers_include
  write_apply_conf
  nginx_test_reload
  return 0
}

add_backend_core() {
  local key="$1" ip="$2" port="$3"
  local url="http://${ip}:${port}"

  if grep -qE "^\s*\"${key}\"" "$NGX_BACKENDS_MAP"; then
    awk -v k="$key" -v url="$url" '
      { re="^[ \t]*\""k"\"";
        if($0~re){ sub(/\"http:\\/\\/[^\\\"]+\"/, "\""url"\"") }
        print
      }' "$NGX_BACKENDS_MAP" > "${NGX_BACKENDS_MAP}.tmp" && mv "${NGX_BACKENDS_MAP}.tmp" "$NGX_BACKENDS_MAP"
    echo -e "${GRN}✅ Actualizado:${NC} $key -> $ip:$port"
  else
    printf "        \"%s\" \"%s\";\n" "$key" "$url" >> "$NGX_BACKENDS_MAP"
    echo -e "${GRN}✅ Agregado:${NC} $key -> $ip:$port"
  fi

  rebuild_balancer_files
  ensure_http_conf_maps
  ensure_mothers_include
  write_apply_conf
  nginx_test_reload
  return 0
}

backend_add_with_days() {
  echo -e "${CYA}Nuevo backend (con vencimiento en días)${NC}"
  echo -e "${DIM}Ejemplo: elnene51 -> 38.242.152.147:80 (30 días)${NC}\n"

  read -r -p "Nombre del backend (ej: elnene51): " key
  validate_key "$key" || { echo -e "${RED}Nombre inválido.${NC}"; return 0; }

  read -r -p "IP (ej: 179.43.112.38): " ip
  validate_ip "$ip" || { echo -e "${RED}IP inválida.${NC}"; return 0; }

  read -r -p "Puerto (ej: 80): " port
  [[ "$port" =~ ^[0-9]{2,5}$ ]] || { echo -e "${RED}Puerto inválido.${NC}"; return 0; }

  read -r -p "Cantidad de días activo (ej: 30): " days
  [[ "$days" =~ ^[0-9]+$ ]] || { echo -e "${RED}Días inválidos.${NC}"; return 0; }
  (( days>=1 && days<=3650 )) || { echo -e "${RED}Días fuera de rango.${NC}"; return 0; }

  add_backend_core "$key" "$ip" "$port" || return 0

  local now exp created_old exp_old line
  now="$(date +%s)"
  line="$(backend_meta_get "$key" || true)"
  if [[ -n "$line" ]]; then
    created_old="$(echo "$line" | awk -F'|' '{print $4}')"
    exp_old="$(echo "$line" | awk -F'|' '{print $5}')"
    [[ -z "$created_old" || "$created_old" == "0" ]] && created_old="$now"
  else
    created_old="$now"
    exp_old="0"
  fi
  exp="$((now + days*86400))"
  backend_meta_upsert "$key" "$ip" "$port" "$created_old" "$exp"

  echo -e "${GRN}📅 Vence:${NC} $(backend_fmt_date "$exp")"

  echo
  read -r -p "¿Generar payload ahora para este backend? (s/N): " yn
  case "${yn,,}" in
    s|si|sí|y|yes)
      payload_generate_for_backend "$key"
      ;;
    *) : ;;
  esac

  return 0
}

backend_list_with_dates() {
  echo -e "${CYA}Backends (IP/puerto + fechas)${NC}\n"
  printf "%-4s %-20s %-18s %-6s %-12s %-12s\n" "#" "BACKEND" "IP" "PORT" "CREADO" "VENCE"
  echo "----------------------------------------------------------------------------"
  local i=0 key url ipport ip port line created exp
  while IFS= read -r line_map; do
    [[ -z "$line_map" ]] && continue
    i=$((i+1))
    key="$(echo "$line_map" | sed -E 's/^\s*"([^"]+)".*$/\1/')"
    url="$(echo "$line_map" | sed -E 's/^.*"\s+"([^"]+)";\s*$/\1/')"
    ipport="${url#http://}"; ip="${ipport%%:*}"; port="${ipport##*:}"

    line="$(backend_meta_get "$key" || true)"
    created="$(echo "$line" | awk -F'|' '{print $4}')"
    exp="$(echo "$line" | awk -F'|' '{print $5}')"
    [[ -z "$created" ]] && created="0"
    [[ -z "$exp" ]] && exp="0"

    printf "%-4s %-20s %-18s %-6s %-12s %-12s\n" "$i" "$key" "$ip" "$port" "$(backend_fmt_date "$created")" "$(backend_fmt_date "$exp")"
  done < <(backend_lines)

  if [[ "$i" -eq 0 ]]; then
    echo -e "${YLW}No hay backends cargados.${NC}"
  fi
  return 0
}

backend_add_days_menu() {
  echo -e "${CYA}Agregar días a un backend${NC}\n"
  mapfile -t lines < <(backend_lines)
  [[ "${#lines[@]}" -gt 0 ]] || { echo -e "${YLW}No hay backends.${NC}"; return 0; }

  local i=0 key url ipport ip port
  for line in "${lines[@]}"; do
    i=$((i+1))
    key="$(echo "$line" | sed -E 's/^\s*"([^"]+)".*$/\1/')"
    url="$(echo "$line" | sed -E 's/^.*"\s+"([^"]+)";\s*$/\1/')"
    ipport="${url#http://}"; ip="${ipport%%:*}"; port="${ipport##*:}"
    printf "%-3s) %-22s -> %s:%s\n" "$i" "$key" "$ip" "$port"
  done

  echo
  read -r -p "Número: " n
  [[ "$n" =~ ^[0-9]+$ ]] || { echo -e "${RED}Inválido.${NC}"; return 0; }
  (( n>=1 && n<=${#lines[@]} )) || { echo -e "${RED}Fuera de rango.${NC}"; return 0; }

  local picked="${lines[$((n-1))]}"
  key="$(echo "$picked" | sed -E 's/^\s*"([^"]+)".*$/\1/')"
  url="$(echo "$picked" | sed -E 's/^.*"\s+"([^"]+)";\s*$/\1/')"
  ipport="${url#http://}"; ip="${ipport%%:*}"; port="${ipport##*:}"

  read -r -p "Sumar días (ej: 30): " days
  [[ "$days" =~ ^[0-9]+$ ]] || { echo -e "${RED}Días inválidos.${NC}"; return 0; }
  (( days>=1 && days<=3650 )) || { echo -e "${RED}Días fuera de rango.${NC}"; return 0; }

  local now line created exp newexp
  now="$(date +%s)"
  line="$(backend_meta_get "$key" || true)"
  created="$(echo "$line" | awk -F'|' '{print $4}')"
  exp="$(echo "$line" | awk -F'|' '{print $5}')"
  [[ -z "$created" || "$created" == "0" ]] && created="$now"
  [[ -z "$exp" ]] && exp="0"

  if [[ "$exp" == "0" ]]; then
    newexp="$((now + days*86400))"
  else
    newexp="$((exp + days*86400))"
  fi

  backend_meta_upsert "$key" "$ip" "$port" "$created" "$newexp"
  echo -e "${GRN}✅ Actualizado.${NC} Vence: $(backend_fmt_date "$newexp")"
  return 0
}

backend_delete_expired() {
  echo -e "${CYA}Eliminar backends expirados${NC}\n"
  [[ -f "$BACKEND_META_FILE" ]] || { echo -e "${YLW}No hay metadatos aún.${NC}"; return 0; }

  local now removed=0
  now="$(date +%s)"

  while IFS='|' read -r k ip port created exp; do
    [[ -z "$k" ]] && continue
    [[ -z "$exp" ]] && exp="0"
    if [[ "$exp" != "0" && "$exp" =~ ^[0-9]+$ && "$exp" -lt "$now" ]]; then
      echo -e "${YLW}🗑️ Expirado:${NC} $k (venció $(backend_fmt_date "$exp"))"
      backend_delete_by_key "$k" >/dev/null 2>&1 && removed=$((removed+1)) || true
    fi
  done < "$BACKEND_META_FILE"

  if [[ "$removed" -eq 0 ]]; then
    echo -e "${GRN}✅ No hay expirados.${NC}"
  else
    echo -e "${GRN}✅ Eliminados:${NC} $removed"
  fi
  return 0
}



# ------------------ PAYLOADS (plantillas + generar con backend) ------------------
PAYLOAD_DIR="${STATE_DIR}/payloads"
PAYLOAD_INDEX="${PAYLOAD_DIR}/index.db"         # id|nombre
PAYLOAD_DOMAINS_FILE="${PAYLOAD_DIR}/domains.list"  # override de dominios (uno por línea)
PAYLOAD_LAST_FILE="${PAYLOAD_DIR}/last_payload.txt"

payload_tpl_file() { echo "${PAYLOAD_DIR}/$1.tpl"; }

payload_init_defaults() {
  mkdir -p "$PAYLOAD_DIR" >/dev/null 2>&1 || true
  [[ -f "$PAYLOAD_INDEX" ]] || : > "$PAYLOAD_INDEX"

  def_ok() {
    local id="$1"
    grep -qE "^${id}\\|" "$PAYLOAD_INDEX" 2>/dev/null || return 1
    [[ -s "$(payload_tpl_file "$id")" ]] || return 1
    return 0
  }

  add_def() {
    local id="$1" name="$2"; shift 2
    local content="$*"
    grep -qE "^${id}\\|" "$PAYLOAD_INDEX" 2>/dev/null || echo "${id}|${name}" >> "$PAYLOAD_INDEX"
    [[ -s "$(payload_tpl_file "$id")" ]] || printf "%s
" "$content" > "$(payload_tpl_file "$id")"
  }

  # Placeholders soportados:
  #  {MOTHERS_ROTATE} -> [rotate=dom1;dom2;dom3]
  #  {MOTHERS_LIST}   -> dom1;dom2;dom3
  #  {HEADER}         -> header actual (ej Backend)
  #  {BACKEND}        -> backend elegido

  if ! def_ok 1; then
    add_def 1 "Payload 1 (GET)" \
"GET / HTTP/1.1[crlf]Host: *.personal.com.ar[crlf][crlf][split]
OPTION / HTTP/1.1[crlf]Host: *.personal.com.ar[crlf][crlf][crlf]GET / HTTP/1.1[crlf]Host: {MOTHERS_ROTATE}[crlf]{HEADER}:{BACKEND}[lf]Upgrade: websocket[crlf]Connection: Upgrade[crlf][crlf]"
  fi
  if ! def_ok 2; then
    add_def 2 "Payload 2 (ACL)" \
"ACL / HTTP/1.1[crlf]Host: recargas.personal.com.ar[crlf][crlf][split]
OPTION / HTTP/1.1[crlf]Host: www.personal.com.ar[crlf][crlf][crlf]GET / HTTP/1.1[crlf]Host: {MOTHERS_LIST}[crlf]{HEADER}:{BACKEND}[lf]Upgrade: websocket[crlf]Connection: Upgrade[crlf][crlf]"
  fi
  if ! def_ok 3; then
    add_def 3 "Payload 3 (Rotate)" \
"[rotate=HEAD;COPY;ACL] / HTTP/1.1[crlf]Host: www.personal.com.ar[crlf][crlf][split]
OPTION / HTTP/1.1[crlf]Host: www.personal.com.ar[crlf][crlf]GET / HTTP/1.1[crlf]Host: {MOTHERS_ROTATE}[crlf]{HEADER}:{BACKEND}[lf]Upgrade: websocket[crlf]Connection: Upgrade[crlf][crlf]"
  fi
  if ! def_ok 4; then
    add_def 4 "Payload 4 (Rotate2)" \
"[rotate=ACL;GET;COPY] / HTTP/1.1[crlf]Host: *.personal.com.ar[crlf][crlf][split]
OPTION / HTTP/1.1[crlf]Host: *.personal.com.ar[crlf][crlf][crlf]GET / HTTP/1.1[crlf]Host: {MOTHERS_ROTATE}[crlf]{HEADER}:{BACKEND}[lf]Upgrade: websocket[crlf]Connection: Upgrade[crlf][crlf]"
  fi
  if ! def_ok 5; then
    add_def 5 "Payload 5 (NPV Tunnel)" \
"GET / HTTP/1.1[crlf]Host: recargas.personal.com.ar[crlf][crlf][split]
OPTION / HTTP/1.1[crlf]Host: recargas.personal.com.ar[crlf][crlf]GET / HTTP/1.1[crlf]Host: {MOTHERS_ROTATE}[crlf]{HEADER}:{BACKEND}[crlf]Upgrade: websocket[crlf]Connection: Upgrade[crlf][crlf]"
  fi
}

payload_domains_from_panel() {
  # dominios desde Dominios madre (servers/*.conf -> server_name)
  mapfile -t files < <(server_files)
  local tmp=() f dom d
  for f in "${files[@]}"; do
    dom="$(grep -E '^\s*server_name\s+' "$f" | head -n1 | sed -E 's/^\s*server_name\s+([^;]+);.*/\1/' || true)"
    [[ -z "$dom" ]] && continue
    for d in $dom; do
      [[ -z "$d" || "$d" == "_" ]] && continue
      [[ "$d" == *.* ]] || continue
      tmp+=("$d")
    done
  done

  # unique (preserva orden)
  local out=() seen="" x
  for x in "${tmp[@]}"; do
    if [[ " $seen " != *" $x "* ]]; then
      out+=("$x"); seen+=" $x"
    fi
  done

  if [[ ${#out[@]} -eq 0 ]]; then
    local pd
    pd="$(primary_domain_active)"
    [[ "$pd" != "(no configurado)" && "$pd" == *.* ]] && out+=("$pd")
  fi

  printf '%s\n' "${out[@]}"
}

payload_get_domains_lines() {
  if [[ -s "$PAYLOAD_DOMAINS_FILE" ]]; then
    grep -vE '^\s*$' "$PAYLOAD_DOMAINS_FILE" 2>/dev/null | head -n 50
  else
    payload_domains_from_panel
  fi
}

payload_domains_join_semicolon() {
  mapfile -t ds < <(payload_get_domains_lines)
  local out="" d
  for d in "${ds[@]}"; do
    d="${d// /}"
    [[ -z "$d" ]] && continue
    if [[ -z "$out" ]]; then out="$d"; else out+=";$d"; fi
  done
  echo "$out"
}

payload_domains_rotate() {
  local list
  list="$(payload_domains_join_semicolon)"
  [[ -z "$list" ]] && { echo "[rotate=]"; return 0; }
  # si hay 1 solo, igual lo envuelvo (mantiene formato)
  echo "[rotate=${list}]"
}

payload_out() {
  # Evita que la UI se "coma" listas por culpa de $(...) capturando stdout
  if [[ -w /dev/tty ]]; then
    echo "/dev/tty"
  else
    echo "/dev/stderr"
  fi
}

payload_print_block() {
  # Imprime un bloque "copiable" para Termius/Bitvise.
  # ✅ Tip: seleccioná desde [START_PAYLOAD] hasta [END_PAYLOAD] y copiá.
  local payload="$1"
  local O; O="$(payload_out)"

  echo >"$O"
  echo ">>> COPY BELOW (seleccioná de [START_PAYLOAD] a [END_PAYLOAD]) <<<" >"$O"
  echo "[START_PAYLOAD]" >"$O"
  printf "%s\n" "$payload" >"$O"
  echo "[END_PAYLOAD]" >"$O"
  echo >"$O"
}



payload_list_templates() {
  payload_init_defaults
  local O; O="$(payload_out)"
  echo -e "${CYA}Plantillas disponibles:${NC}" >"$O"
  if [[ ! -s "$PAYLOAD_INDEX" ]]; then
    echo -e "${YLW}No hay plantillas.${NC}" >"$O"
    return 0
  fi
  while IFS='|' read -r id name; do
    [[ -z "$id" ]] && continue
    local first
    first="$(head -n1 "$(payload_tpl_file "$id")" 2>/dev/null | tr -d '\r')"
    [[ -z "$first" ]] && first="(vacía)"
    printf " %3s) %-22s  %s\n" "$id" "$(disp_trunc "$name" 22)" "$(disp_trunc "$first" 38)" >"$O"
  done < <(sort -t'|' -k1,1n "$PAYLOAD_INDEX" 2>/dev/null)
  echo >"$O"
}

payload_pick_template_id() {
  # Usage:
  #   payload_pick_template_id VAR   -> guarda el ID en VAR (recomendado)
  #   payload_pick_template_id       -> imprime el ID por stdout (legacy)
  payload_list_templates
  local __var="${1:-}"
  local id O; O="$(payload_out)"
  if [[ -r /dev/tty ]]; then
    read -r -p "ID de plantilla (Enter=1): " id </dev/tty
  else
    read -r -p "ID de plantilla (Enter=1): " id
  fi
  id="${id:-1}"
  [[ "$id" =~ ^[0-9]+$ ]] || { echo -e "${YLW}ID inválido.${NC}" >"$O"; return 1; }
  if ! grep -qE "^${id}\|" "$PAYLOAD_INDEX" 2>/dev/null || [[ ! -s "$(payload_tpl_file "$id")" ]]; then
    echo -e "${YLW}Plantilla no encontrada o vacía.${NC}" >"$O"
    return 1
  fi
  if [[ -n "$__var" ]]; then
    printf -v "$__var" "%s" "$id"
  else
    echo "$id"
  fi
